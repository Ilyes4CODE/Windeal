# Copy to `.env` on the server and fill in real values. NEVER commit the real .env.
# Generate a secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Comma-separated. Your domain and/or the server IP.
DJANGO_ALLOWED_HOSTS=api.windeal.dz,187.77.171.86

# Comma-separated https origins for the Django admin / CSRF (behind Nginx TLS).
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.windeal.dz

# PostgreSQL connection string.
DATABASE_URL=postgres://windeal:STRONG_DB_PASSWORD@127.0.0.1:5432/windeal

# Redis for the Channels layer (WebSockets). Leave blank to use the in-memory
# layer (single process only).
REDIS_URL=redis://127.0.0.1:6379/0

# CORS — a mobile app hitting the API directly is fine with allow-all.
# To restrict to web origins, set to False and list DJANGO_CORS_ALLOWED_ORIGINS.
DJANGO_CORS_ALLOW_ALL=True
# DJANGO_CORS_ALLOWED_ORIGINS=https://app.windeal.dz

# Enable HSTS only after HTTPS is confirmed working (seconds; e.g. 31536000).
DJANGO_HSTS_SECONDS=0
